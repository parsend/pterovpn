    <string-array name="guide_configs_steps">
        <item>Open the Configs tab.</item>
        <item>Local: Add, enter host:port:key, save.</item>
        <item>Switch to the Cloud tab, Refresh cloud, then Connect on a card.</item>
        <item>Edit or Delete on the card.</item>
    </string-array>
    <string-array name="guide_protection_steps">
        <item>Open Protect tab.</item>
        <item>Pick Balance, Strong, or Auto from session metrics.</item>
        <item>Set obfuscation, junk, pad if needed.</item>
        <item>Save or Clear at the bottom.</item>
    </string-array>
    <string-array name="guide_logs_steps">
        <item>Open Logs tab.</item>
        <item>Empty until you Connect from Configs.</item>
        <item>Scroll, filter by tag, search text.</item>
    </string-array>
    <string-array name="guide_settings_steps">
        <item>Open Settings tab.</item>
        <item>TUN or Proxy; for proxy set listen.</item>
        <item>In TUN: IPv6, transport, dual tun-tcp.</item>
        <item>Save. Updates: Check for updates.</item>
    </string-array>
    <string name="home_guide_configs_hint">Local JSON and cloud list in one place.</string>
