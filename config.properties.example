listenPorts=0
token=your-secret-key
udpChannels=4
publicHost=1.2.3.4
debug=true

# tcp-only | quic-only | both
serverMode=tcp-only

# quicListenPort=4433
# quicCertPath=quic/auto.crt
# quicKeyPath=quic/auto.key

# quicAlpn=pteravpn
# obfsProfileId=0
# при 1 клиент после probe усиливает junk/tls-преамбулу и фрагментацию без правки protection.json
# quicMaxStreams=0
# quicMaxHandshakes=0
# quicIdleTimeoutMs=900000
# quicHandshakeTimeoutMs=60000
# quicTcpConnectTimeoutMs=10000
# quicIngressRingSlots=4096

update.enabled=true
update.repo=unitdevgcc/pterovpn
update.checkIntervalMinutes=1
update.restartExitCode=1
